{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Dashboard",
  "version": "0.1.0",
  "identifier": "com.openclaw.dashboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "shortDescription": "OpenClaw Dashboard",
    "longDescription": "OpenClaw Dashboard - AI Agent Management Interface",
    "category": "public.app-category.productivity"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  }
}
