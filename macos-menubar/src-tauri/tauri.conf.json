{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Dashboard",
  "version": "0.1.0",
  "identifier": "com.openclaw.dashboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "echo 'Dashboard should be running on localhost:3000'",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenClaw Dashboard",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "shortDescription": "OpenClaw Dashboard",
    "longDescription": "OpenClaw Dashboard - AI Agent Management Interface",
    "category": "public.app-category.productivity"
  }
}
