{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Menubar",
  "version": "0.1.0",
  "identifier": "com.openclaw.menubar",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenClaw Dashboard",
        "width": 300,
        "height": 400,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "shortDescription": "OpenClaw Dashboard Service Control",
    "longDescription": "Menu bar application for controlling OpenClaw Dashboard service",
    "category": "public.app-category.utilities"
  }
}
